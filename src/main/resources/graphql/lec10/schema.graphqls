type Query{
    products: [Product]
}

interface Product{
    id: ID
    description: String
    price: Int
}

type Fruit implements Product {
    id: ID!
    description: String
    price: Int
    expiryDate: String
}

type Electronic implements Product {
    id: ID!
    description: String
    price: Int
    brand: Brand
}

type Book implements Product {
    id: ID!
    description: String
    price: Int
    author: String
}

enum Brand{
    APPLE
    SAMSUNG
}
